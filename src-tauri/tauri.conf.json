{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TSA",
  "version": "0.1.0",
  "identifier": "com.tsa.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TSA",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TestModelAlive",
  "version": "0.1.0",
  "identifier": "com.testmodelalive.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TestModelAlive",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
